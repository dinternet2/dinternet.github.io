/* ---------- render ---------- */
let mode = 'new';

function accHTML(item){
  const removed = item.removed ? ' removed' : '';
  const title = item.newOnly
    ? item.newTitle + ' <span class="badge-remove" style="background:var(--orange)">NEU</span>'
    : (item.removed ? item.newTitle + ' <span class="badge-remove">'+item.removeLabel+'</span>' : item.newTitle);

  let body;
  if(mode==='cmp'){
    const oldCol = item.oldTitle
      ? `<div class="col old"><div class="coltag">Bisher · ${item.oldTitle}</div><div class="body-text">${item.old||'<p class="none-note">– kein bisheriger Text –</p>'}</div></div>`
      : `<div class="col old"><div class="coltag">Bisher</div><p class="none-note">Dieses Akkordeon existierte bisher nicht.</p></div>`;
    const newCol = `<div class="col new"><div class="coltag">Neu · ${stripSmall(item.newTitle)}</div><div class="body-text">${item.new}</div></div>`;
    body = `<div class="cmp ${item.newOnly?'new-only':''}">${oldCol}${newCol}</div>`;
  } else {
    body = `<div class="body-text">${item.new}</div>`;
  }
  const note = item.note ? `<div class="note-card"><b>Hinweis:</b> ${item.note}</div>` : '';

  return `<div class="acc${removed}">
    <button class="acc-head" onclick="this.parentNode.classList.toggle('open');syncToggleLabel()" aria-expanded="false">
      <span class="num">${item.num}</span>
      <span class="acc-title">${title}</span>
      <span class="chev">⌄</span>
    </button>
    <div class="acc-body">${note}${body}</div>
  </div>`;
}
function stripSmall(t){return t.replace(/<small>.*?<\/small>/,'').trim();}

function render(){
  document.getElementById('sectionA').innerHTML = sectionA.map(accHTML).join('');
  document.getElementById('sectionB').innerHTML = sectionB.map(accHTML).join('');
  attachTooltips();
}
function setMode(m){
  mode=m;
  document.getElementById('mode-new').classList.toggle('active',m==='new');
  document.getElementById('mode-cmp').classList.toggle('active',m==='cmp');
  // remember open state by index
  const openA=[...document.querySelectorAll('#sectionA .acc')].map(a=>a.classList.contains('open'));
  const openB=[...document.querySelectorAll('#sectionB .acc')].map(a=>a.classList.contains('open'));
  render();
  document.querySelectorAll('#sectionA .acc').forEach((a,i)=>{if(openA[i])a.classList.add('open');});
  document.querySelectorAll('#sectionB .acc').forEach((a,i)=>{if(openB[i])a.classList.add('open');});
  syncToggleLabel();
}
function toggleAll(){
  const accs=[...document.querySelectorAll('.acc')];
  const anyClosed=accs.some(a=>!a.classList.contains('open'));
  accs.forEach(a=>a.classList.toggle('open',anyClosed));
  syncToggleLabel();
}
function syncToggleLabel(){
  const accs=[...document.querySelectorAll('.acc')];
  const anyClosed=accs.some(a=>!a.classList.contains('open'));
  document.getElementById('toggleAll').textContent=anyClosed?'Alle öffnen':'Alle schliessen';
}

/* simple tooltip for flags */
function attachTooltips(){
  document.querySelectorAll('.flag[data-note]').forEach(f=>{
    f.setAttribute('title', f.getAttribute('data-note'));
  });
}

render();
syncToggleLabel();
</script>
